# ─── Frontend (Next.js + Convex) ───
NEXT_PUBLIC_CONVEX_URL="https://your-project-id.convex.cloud"
CONVEX_DEPLOYMENT="dev:your-project-id"

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_JWT_ISSUER_DOMAIN="https://your-clerk-issuer-domain.clerk.accounts.dev"

# Backend API URL (for frontend → backend communication)
NEXT_PUBLIC_API_URL="http://localhost:8000"

# ─── Backend (FastAPI) ───

# LLM — OpenRouter (powers Qwen 2.5, Qwen 3 VL, Kimi-K2.5)
OPENROUTER_API_KEY="sk-or-v1-..."

# Web Search Grounding — SerpAPI
SERPAPI_API_KEY="your-serpapi-key"

# Video Generation — HuggingFace Space (LTX-2.3)
HF_TOKEN="hf_..."

# ─── WhatsApp Demo (Optional — Pipeline B) ───
TWILIO_ACCOUNT_SID="ACxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxx"
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"
NGROK_AUTHTOKEN="your-ngrok-auth-token"

# ─── Malaysian AI Models ───
# No API keys needed — models auto-download from HuggingFace
# GPU: Requires NVIDIA CUDA for fast inference
# CPU: Works but slower (~10x)
# Primary ASR: mesolitica/whisper-50TPS-VQ-32k-large-v3-turbo
# Enhanced ASR: mesolitica/gemma3n-audio-encoder-whisper-decoder
