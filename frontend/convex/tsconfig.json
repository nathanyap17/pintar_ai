{
    "compilerOptions": {
        "target": "ESNext",
        "lib": [
            "ES2021",
            "DOM"
        ],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "allowJs": true,
        "strict": true,
        "noEmit": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "paths": {
            "convex/_generated/*": [
                "./_generated/*"
            ]
        }
    },
    "include": [
        "./**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}